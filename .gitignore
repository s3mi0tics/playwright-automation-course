cat > .gitignore << 'EOF'
# Dependencies
node_modules/

# Angular
.angular/
/dist
/tmp
/out-tsc
/.sass-cache
/connect.lock
/coverage
/libpeerconnection.log
npm-debug.log
testem.log
/typings
/docs

# Playwright
**/playwright-report/
**/test-results/
**/blob-report/
**/playwright/.cache/

# Auth tokens - sensitive
auth/
.auth/
**/auth/
**/.auth/

# IDE
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.idea/
*.sublime-workspace

# System
.DS_Store
Thumbs.db

# CI (not ready yet)
.github/

# e2e
/e2e/*.js
/e2e/*.map
EOF